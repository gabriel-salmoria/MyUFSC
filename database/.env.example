# ── Database provider ─────────────────────────────────────────────────────────
# Explicitly choose the database backend. This is the primary signal.
#
#   neon   → uses NEON_URL (production / Vercel)
#   local  → uses in-process PGlite stored in .dev-db/ (no server needed)
#
# On Vercel: set DB_PROVIDER=neon in your project environment variables.
# Locally:   set DB_PROVIDER=local here, OR create myufsc.config.local.json:
#              { "database": { "provider": "local" } }
#
DB_PROVIDER=local

# Required when DB_PROVIDER=neon:
# NEON_URL=postgresql://<user>:<pass>@<host>/neondb?sslmode=require

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_KEY=
