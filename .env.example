# ── Database ──────────────────────────────────────────────────────────────────
# The database provider is configured in myufsc.config.json (committed).
# For local development, create myufsc.config.local.json (gitignored) with:
#   { "database": { "provider": "local" } }
# That uses an in-process PGlite database — no server or URL needed.
#
# For production / Neon (myufsc.config.json has provider: "neon"):
# NEON_URL=postgresql://<user>:<pass>@<host>/neondb?sslmode=require

